{
  "name": "@akira-io/efatura",
  "version": "1.0.0-beta2",
  "description": "Cabo Verde e-Fatura fiscal document validation engine for Node.js",
  "license": "(MIT OR Apache-2.0)",
  "author": "Kidiatoliny <kidiatoliny@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akira-io/node-efatura.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./knex": {
      "types": "./dist/storage/knex/index.d.ts",
      "import": "./dist/storage/knex/index.js",
      "require": "./dist/storage/knex/index.cjs"
    },
    "./prisma": {
      "types": "./dist/storage/prisma/index.d.ts",
      "import": "./dist/storage/prisma/index.js",
      "require": "./dist/storage/prisma/index.cjs"
    },
    "./express": {
      "types": "./dist/express/index.d.ts",
      "import": "./dist/express/index.js",
      "require": "./dist/express/index.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "import": "./dist/fastify/index.js",
      "require": "./dist/fastify/index.cjs"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "import": "./dist/nest/index.js",
      "require": "./dist/nest/index.cjs"
    }
  },
  "files": [
    "assets",
    "dist",
    "docs",
    "prisma",
    "resources",
    "README.md",
    "LICENSE.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.3",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "knex": "^3.3.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "sideEffects": false,
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "xml-crypto": "^6.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "@prisma/client": ">=5",
    "express": ">=4.18",
    "fastify": ">=4",
    "knex": ">=3",
    "reflect-metadata": ">=0.2"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "knex": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "trustedDependencies": [
    "@prisma/adapter-better-sqlite3",
    "@prisma/client",
    "better-sqlite3",
    "prisma"
  ]
}
